#!/usr/bin/env bash
# agent-the-zsh installer — curl -fsSL https://21stware.github.io/agent-the-zsh/install | bash
#
# Detects your OS/arch, downloads the matching release tarball from GitHub, and
# runs the bundled installer (binaries -> ~/.local/bin, widget -> ~/.local/share/flow,
# and a marked block in ~/.zshrc that starts the daemon and loads the widget).
#
# If no prebuilt release matches and Go is available, it falls back to building
# from source via `go install`-style cloning.
#
# Env:
#   PREFIX=/usr/local   install location (default: ~/.local)
#   FLOW_VERSION=vX.Y.Z  pin a release tag (default: latest)
set -euo pipefail

REPO="21stware/agent-the-zsh"
PREFIX="${PREFIX:-$HOME/.local}"
VERSION="${FLOW_VERSION:-latest}"

say()  { printf '\033[36m▸\033[0m %s\n' "$*"; }
warn() { printf '\033[33m!\033[0m %s\n' "$*" >&2; }
die()  { printf '\033[31m✗\033[0m %s\n' "$*" >&2; exit 1; }

# --- detect platform ---
os=$(uname -s | tr '[:upper:]' '[:lower:]')
arch=$(uname -m)
case "$arch" in
  x86_64|amd64) arch=amd64 ;;
  arm64|aarch64) arch=arm64 ;;
  *) die "unsupported arch: $arch" ;;
esac
case "$os" in
  darwin|linux) ;;
  *) die "unsupported OS: $os (flow needs zsh; macOS or Linux)" ;;
esac

command -v zsh >/dev/null 2>&1 || warn "zsh not found on PATH — flow is a zsh tool; install zsh first."

tarball="flow-${os}-${arch}.tar.gz"
tmp=$(mktemp -d)
trap 'rm -rf "$tmp"' EXIT

# --- resolve the release download URL ---
if [[ "$VERSION" == "latest" ]]; then
  url="https://github.com/$REPO/releases/latest/download/$tarball"
else
  url="https://github.com/$REPO/releases/download/$VERSION/$tarball"
fi

say "Downloading $tarball ($VERSION)…"
if curl -fsSL "$url" -o "$tmp/$tarball" 2>/dev/null; then
  say "Unpacking…"
  tar -C "$tmp" -xzf "$tmp/$tarball"
  ( cd "$tmp/flow" && PREFIX="$PREFIX" ./install.sh )
  exit 0
fi

# --- fallback: build from source ---
warn "No prebuilt $tarball for $os/$arch — falling back to building from source."
command -v go >/dev/null 2>&1 || die "Go is not installed and no prebuilt binary is available. Install Go 1.25+ or grab a release."
command -v git >/dev/null 2>&1 || die "git is required for the source fallback."

say "Cloning $REPO…"
git clone --depth 1 "https://github.com/$REPO.git" "$tmp/src" >/dev/null 2>&1 \
  || die "clone failed"
say "Building + installing…"
make -C "$tmp/src" install PREFIX="$PREFIX"
